rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if the user is an admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // USER DATA
    match /users/{userId} {
      // User can read/write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admin can read all users (needed for Dashboard "Total Users")
      allow read, write: if isAdmin();
    }

    // INVENTORY DATA: Publicly readable, strictly Admin writable
    match /books/{bookId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /courses/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /universities/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Explicitly allow collectionGroup queries for questions and questionPdfs
    match /{path=**}/questions/{question} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /{path=**}/questionPdfs/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ANALYTICS TRACKING
    match /stats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /daily_stats/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
